# ── Active provider ────────────────────────────────────────────────────────────
# Set to: openai | anthropic | groq | google
ACTIVE_PROVIDER=groq

# ── API keys (only the one matching ACTIVE_PROVIDER is required) ────────────────

# Groq — free tier, no billing needed
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenAI — requires prepaid credits ($5 min)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — requires prepaid credits
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — requires billing enabled on GCP project
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AI...
